# Copy to .env and adjust. Vite embeds VITE_* at build time — set production values in CI or before `npm run build`.

# .NET API origin (no trailing slash). Examples:
#   Local:     http://localhost:5000
#   Dev API:   https://api.dev.example.com
# If unset in production builds: same-origin URLs (/api/v1/...) — your web server must proxy /api to this backend.
VITE_API_BASE_URL=
